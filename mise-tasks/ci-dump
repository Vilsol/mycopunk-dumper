#!/usr/bin/env bash
#MISE description="Headless dump for CI: launches Mycopunk.exe directly under Proton (no Steam client). Same data.json contract as 'dump'. Requires PROTON_DIR pointing at an extracted Proton install."
#MISE depends=["deploy"]
set -uo pipefail

: "${PROTON_DIR:?PROTON_DIR unset (must point at an extracted Proton install)}"
: "${UMU_RUN:?UMU_RUN unset (must point at the umu-run zipapp)}"

DATA="$MYCOPUNK_DIR/data.json"
LOG="$MYCOPUNK_DIR/BepInEx/LogOutput.log"
UNITY_LOG="$MYCOPUNK_DIR/unity.log"

rm -f "$DATA" "$LOG" "$UNITY_LOG"

# Skip the "is Steam running?" check inside Steamworks SDK. Without this the
# game hangs forever in SteamAPI_Init() because there's no Steam client in CI.
echo "$MYCOPUNK_APPID" > "$MYCOPUNK_DIR/steam_appid.txt"
export SteamAppId="$MYCOPUNK_APPID"
export SteamGameId="$MYCOPUNK_APPID"

# umu-launcher creates and manages its own Wine prefix under WINEPREFIX; it
# wires up STEAM_COMPAT_* internally so we don't need to set those ourselves.
export WINEPREFIX="$MYCOPUNK_DIR/_umu_prefix"
mkdir -p "$WINEPREFIX"

# Unity 6 in -batchmode -nographics still allocates a hidden window for
# input event routing; without ANY display it dies with "Failed to create
# batch mode window: Success." Run under xvfb with explicit 24-bit screen
# depth (default 8-bit makes Unity 6 unhappy) and the RANDR extension
# enabled (Unity probes for it).
#
# Launch via umu-run rather than 'proton run' directly: umu sets up Steam's
# Linux runtime container so Proton-bundled tools like Xalia find the
# libraries they expect. Without it, Xalia init throws "Video driver
# not supported" before our game even starts.
#
# GAMEID=umu-default + STORE=none = "no umu-database fixes needed";
# PROTONPATH points at the Proton install our workflow already pre-extracted.
# -logFile redirects Unity's Player.log out of the Proton prefix into
# MYCOPUNK_DIR/unity.log so we can actually read it.
# MONO_LOG_LEVEL=debug + MONO_LOG_MASK=type prints every type load attempt
# (verbose) so we can see exactly which Type fails when BepInEx's Chainloader
# does AddComponent(MycopunkDumper.Plugin). Unity's bundled Mono respects
# these env vars. We funnel the chatter into a separate file so it doesn't
# drown the main stdout.
MONO_TRACE="$MYCOPUNK_DIR/mono-trace.log"
rm -f "$MONO_TRACE"

xvfb-run --auto-servernum --server-args="-screen 0 1024x768x24 +extension RANDR" -- env \
    WINEDLLOVERRIDES="winhttp.dll=n,b" \
    GAMEID="umu-default" \
    STORE="none" \
    PROTONPATH="$PROTON_DIR" \
    PROTON_XALIA=0 \
    MONO_LOG_LEVEL=debug \
    MONO_LOG_MASK=type \
    "$UMU_RUN" "$MYCOPUNK_DIR/Mycopunk.exe" \
    -batchmode -nographics -logFile "Z:$UNITY_LOG" 2>>"$MONO_TRACE" &
GAME_PID=$!

echo "Launched Mycopunk under Proton (pid $GAME_PID) at $(date +%T); waiting for data.json (up to 5min)..."

for _ in $(seq 1 100); do
    if [[ -s "$DATA" ]]; then break; fi
    sleep 3
done

if [[ ! -s "$DATA" ]]; then
    echo "ERROR: timeout — data.json never appeared." >&2
    echo "--- BepInEx LogOutput.log (full) ---" >&2
    cat "$LOG" >&2 2>/dev/null || echo "(no BepInEx log)" >&2
    echo "--- Unity Player log (last 60) ---" >&2
    tail -60 "$UNITY_LOG" >&2 2>/dev/null || echo "(no unity log)" >&2
    echo "--- Any data.json under MYCOPUNK_DIR (in case Paths.GameRootPath resolved unexpectedly) ---" >&2
    find "$MYCOPUNK_DIR" -name 'data.json' -size +0 2>/dev/null >&2 || true
    echo "--- steam_api*.dll inventory (size + sha256) ---" >&2
    while IFS= read -r -d '' f; do
        printf '%s  %s  %s\n' "$(stat -c%s "$f")" "$(sha256sum "$f" | cut -d' ' -f1)" "$f" >&2
    done < <(find "$MYCOPUNK_DIR" -iname 'steam_api*.dll' -print0)
    echo "--- Mono type-trace lines mentioning TypeLoadException or our plugin ---" >&2
    command grep -E "TypeLoadException|MycopunkDumper|Failed to load|Could not load" "$MONO_TRACE" 2>/dev/null | head -40 >&2 || echo "(no mono-trace match)" >&2
    kill "$GAME_PID" 2>/dev/null || true
    exit 1
fi

SIZE=$(stat -c%s "$DATA")
echo "Wrote $DATA ($SIZE bytes) at $(date +%T)"

kill "$GAME_PID" 2>/dev/null || true
pkill -f Mycopunk.exe >/dev/null 2>&1 || true

LABELS="$(dirname "$(realpath "$0")")/../property-labels.json"
ENRICH="$(dirname "$(realpath "$0")")/../scripts/dump-enrich.py"
if [[ -s "$LABELS" ]]; then
    python3 "$ENRICH" "$DATA" "$LABELS"
else
    echo "(skipping label enrichment — run 'mise run extract-labels' to enable)"
fi
