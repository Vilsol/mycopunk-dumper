#!/usr/bin/env bash
#MISE description="Deploy plugin, launch Mycopunk headlessly, capture data.json. Steam must be running with launch options: WINEDLLOVERRIDES=\"winhttp.dll=n,b\" %command% -batchmode -nographics"
#MISE depends=["deploy"]
set -uo pipefail

DATA="$MYCOPUNK_DIR/data.json"
LOG="$MYCOPUNK_DIR/BepInEx/LogOutput.log"

if ! pgrep -f "steamwebhelper " >/dev/null; then
    echo "ERROR: Steam is not running. Start Steam first." >&2
    exit 1
fi

# Kill any running instance so the new DLL is loaded
pkill -f Mycopunk.exe >/dev/null 2>&1 || true
sleep 2

# Clear stale outputs so we can detect the new dump
rm -f "$DATA" "$LOG"

# Launch via Steam URI; the steam binary returns immediately
steam "steam://rungameid/$MYCOPUNK_APPID" >/dev/null 2>&1 || true
echo "Launched Mycopunk (app $MYCOPUNK_APPID) at $(date +%T); waiting for data.json (up to 5min)..."

for _ in $(seq 1 100); do
    if [[ -s "$DATA" ]]; then break; fi
    sleep 3
done

if [[ ! -s "$DATA" ]]; then
    echo "ERROR: timeout — data.json never appeared. Last log lines:" >&2
    tail -20 "$LOG" >&2 2>/dev/null || true
    exit 1
fi

SIZE=$(stat -c%s "$DATA")
echo "Wrote $DATA ($SIZE bytes) at $(date +%T)"

# In -batchmode the game self-exits; kill defensively if still up
pkill -f Mycopunk.exe >/dev/null 2>&1 || true

# Optional post-processing: if property-labels.json exists (built by `mise run extract-labels`
# from decompiled source), enrich each Properties[i] entry in data.json with the full set
# of localization keys that property class can emit — including keys hidden inside conditionals
# / switch expressions that runtime sampling can miss.
LABELS="$(dirname "$(realpath "$0")")/../property-labels.json"
ENRICH="$(dirname "$(realpath "$0")")/../scripts/dump-enrich.py"
if [[ -s "$LABELS" ]]; then
    python3 "$ENRICH" "$DATA" "$LABELS"
else
    echo "(skipping label enrichment — run 'mise run extract-labels' to enable)"
fi
