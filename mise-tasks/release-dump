#!/usr/bin/env bash
#MISE description="Publish $MYCOPUNK_DIR/data.json into a mycopunk-data repo: gzip, generate CHANGES.md vs previous version, refresh index.json + _redirects + schema."
set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "Usage: mise run release-dump <data-repo-path> [--force]" >&2
    echo "" >&2
    echo "Reads version from \$MYCOPUNK_DIR/data.json (run 'mise run dump' first)." >&2
    echo "Bails if data/<version>/ already exists in the data repo unless --force is given." >&2
    exit 2
fi

DATA_REPO="$(realpath "$1")"
FORCE="${2:-}"
DUMP_SRC="$MYCOPUNK_DIR/data.json"
DUMPER_REPO="$(realpath "$(dirname "$0")/..")"

if [ ! -f "$DUMP_SRC" ]; then
    echo "No dump found at $DUMP_SRC — run 'mise run dump' first." >&2
    exit 1
fi
if [ ! -d "$DATA_REPO" ]; then
    echo "Data repo not found: $DATA_REPO" >&2
    exit 1
fi
if [ ! -f "$DATA_REPO/index.json" ]; then
    echo "Not a mycopunk-data repo (missing index.json): $DATA_REPO" >&2
    exit 1
fi

VERSION=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["gameVersion"]["Version"])' "$DUMP_SRC")
BUILD_ID=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["gameVersion"]["BuildID"])' "$DUMP_SRC")
DUMPED_AT=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["gameVersion"]["DumpedAt"])' "$DUMP_SRC")
DUMPER_COMMIT=$(git -C "$DUMPER_REPO" rev-parse --short HEAD 2>/dev/null || echo "unknown")

if [ -z "$VERSION" ] || [ "$VERSION" = "None" ]; then
    echo "Could not read gameVersion.Version from $DUMP_SRC" >&2
    exit 1
fi

OUT_DIR="$DATA_REPO/data/$VERSION"
if [ -d "$OUT_DIR" ] && [ "$FORCE" != "--force" ]; then
    echo "Already exists: $OUT_DIR (re-dumping the same version is destructive — pass --force to overwrite)" >&2
    exit 1
fi

mkdir -p "$OUT_DIR"

# 1. gzip the dump
gzip -9 -c "$DUMP_SRC" > "$OUT_DIR/data.json.gz"
SIZE=$(stat -c %s "$OUT_DIR/data.json.gz")
SHA256=$(sha256sum "$OUT_DIR/data.json.gz" | awk '{print $1}')

# 2. copy the current schema
mkdir -p "$DATA_REPO/schema"
cp "$DUMPER_REPO/data.schema.json" "$DATA_REPO/schema/data.schema.json"

# 3. generate CHANGES.md vs previous version (if any)
PREV_VERSION=$(python3 -c '
import json, sys
idx = json.load(open(sys.argv[1]))
this = sys.argv[2]
prev = next((v["version"] for v in idx["versions"] if v["version"] != this), "")
print(prev)
' "$DATA_REPO/index.json" "$VERSION")

if [ -n "$PREV_VERSION" ] && [ -f "$DATA_REPO/data/$PREV_VERSION/data.json.gz" ]; then
    echo "Generating CHANGES.md vs $PREV_VERSION..."
    PREV_TMP=$(mktemp --suffix=.json)
    gunzip -c "$DATA_REPO/data/$PREV_VERSION/data.json.gz" > "$PREV_TMP"
    {
        echo "# Changes from $PREV_VERSION → $VERSION"
        echo ""
        echo "Generated by \`tools/diff.py\` ($DUMPER_COMMIT) on $DUMPED_AT."
        echo ""
        echo '```'
        NO_COLOR=1 python3 "$DUMPER_REPO/tools/diff.py" "$PREV_TMP" "$DUMP_SRC" || true
        echo '```'
    } > "$OUT_DIR/CHANGES.md"
    rm "$PREV_TMP"
else
    {
        echo "# Changes from (initial) → $VERSION"
        echo ""
        echo "First snapshot — no previous version to diff against."
    } > "$OUT_DIR/CHANGES.md"
fi

# 4. update index.json: insert/replace this version's entry, set latest, sort newest-first by dumpedAt
python3 - "$DATA_REPO/index.json" "$VERSION" "$BUILD_ID" "$DUMPED_AT" "$DUMPER_COMMIT" "$SIZE" "$SHA256" <<'PY'
import json, sys
path, version, build_id, dumped_at, dumper_commit, size, sha256 = sys.argv[1:]
idx = json.load(open(path))
versions = [v for v in idx.get("versions", []) if v["version"] != version]
versions.append({
    "version": version,
    "buildId": build_id,
    "dumpedAt": dumped_at,
    "dumperCommit": dumper_commit,
    "size": int(size),
    "sha256": sha256,
})
versions.sort(key=lambda v: v["dumpedAt"], reverse=True)
idx["versions"] = versions
idx["latest"] = versions[0]["version"]
idx.setdefault("schema", "/schema/data.schema.json")
with open(path, "w") as f:
    json.dump(idx, f, indent=2)
    f.write("\n")
PY

# 5. update _redirects: /latest/* → newest version path
LATEST=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["latest"])' "$DATA_REPO/index.json")
{
    echo "# Auto-generated by 'mise run release-dump' — do not hand-edit."
    echo "# 302 (not 301) so consumers don't cache the alias permanently."
    echo "/latest/*  /data/$LATEST/:splat  302"
} > "$DATA_REPO/_redirects"

cat <<EOF

Released $VERSION → $OUT_DIR
  size: $SIZE bytes (gz)
  sha256: $SHA256
  build: $BUILD_ID
  dumper: $DUMPER_COMMIT
  CHANGES.md: $(wc -l < "$OUT_DIR/CHANGES.md") lines

Next:
  cd $DATA_REPO
  git add data/$VERSION schema/data.schema.json index.json _redirects
  git commit -m "release $VERSION (build $BUILD_ID)"
  git push
EOF
